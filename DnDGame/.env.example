# Copy this file to .env and fill in values for a real deployment.
# None of these are required for local/LAN play with `npm start`.

# Your domain name, once you have one pointed at this server (used by Caddy
# for automatic HTTPS). Leave unset for local-only/LAN use.
DOMAIN=

# Lock CORS down to your real domain once you have one. "*" (the default if
# unset) is fine for local/LAN play.
ALLOWED_ORIGIN=

# Your own TURN server credentials, for reliable voice/video across
# different networks (see README "Hosting for real" section). If unset, a
# public demo TURN server is used as a fallback -- it works, but it's
# unauthenticated, rate-limited, and not something to depend on long-term.
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
